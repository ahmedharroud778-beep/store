PORT=5000
# If set, uses Postgres instead of local SQLite file (recommended for hosts without persistent disks).
# Example (Supabase/Neon): postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Optional: set a single persistent directory for ALL store data
# (products, categories, orders, custom requests, and SQLite DB).
# Example (Render persistent disk mount):
# DATA_DIR=/var/data/baraa-store
DATA_DIR=

# Optional: override DB file location directly (defaults to DATA_DIR/baraa-store.db)
DB_PATH=server/data/baraa-store.db
# Optional: where uploaded images are written (and served at /uploads/*)
# Example (Render persistent disk mount):
# UPLOADS_DIR=/var/data/baraa-store/uploads
UPLOADS_DIR=uploads

# Optional: store uploaded images in Cloudinary instead of the server disk.
# If these are set, uploads will return Cloudinary HTTPS URLs and will persist even on free hosts.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=baraa-store
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_JWT_SECRET=replace-with-long-random-secret
